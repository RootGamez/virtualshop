# Headers de seguridad del panel admin, servidos por Cloudflare Pages.
# X-Robots-Tag refuerza el <meta name="robots"> del index.html: un panel de
# administración nunca debe aparecer en buscadores.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex, nofollow
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
